# Template — copy to credentials.conf and fill in your values before use.
# credentials.conf contains plaintext passwords — keep it secure, never commit it.

# SD card volume label prefix (e.g. "pi5" → pi5boot, pi5root)
PREFIX="pi"

# Hostname
HOSTNAME="mypi"

# Passwords
ALARM_PWD="yourpassword"
ROOT_PWD="yourrootpassword"

# WiFi — leave WIFI_SSID empty to skip WiFi setup
WIFI_SSID=""
WIFI_PSK=""
WIFI_COUNTRY="DE"
